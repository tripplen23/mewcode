# Required
OPENCODE_GO_API_KEY=

# Optional
# MEWCODE_DATA_DIR overrides where sessions are stored
# (defaults to $XDG_DATA_HOME/mewcode or ~/.local/share/mewcode)
# MEWCODE_DATA_DIR=
MEWCODE_PORT=3737
MEWCODE_HOST=127.0.0.1
RUST_LOG=info,mewcode_engine=debug
MEWCODE_THEME=catppuccin-mocha

# Langfuse tracing
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL="https://cloud.langfuse.com"
