# Build artifacts
target/
**/target/

# cargo backup files (from `rustup` switching toolchains, etc.)
*.rs.bk
**/*.rs.bk
Cargo.lock.bak

# MSVC Windows builds of rustc emit these debug symbols
*.pdb
**/*.pdb

# Local config & secrets — never commit these
.env
.env.local
.envrc
**/.env
**/.env.local

# Docker volumes (postgres data lives here per docker-compose.yml)
data/

# Logs
*.log
**/*.log

# OS files
.DS_Store
Thumbs.db

# IDE / editor
.idea/
.vscode/
*.swp
*.swo
*~

.kiro/
PROMPT.md
.env

# Runtime data the engine produces (canvas files, session snapshots).
# Keep this out of git: regenerable, contains user content.
.mewcode/

# Proptest regression files (seeds for failing cases). Keep out of git;
# CI regenerates them when a property test fails, and committing them
# pollutes diffs with machine-specific test output.
*.proptest-regressions
**/*.proptest-regressions
